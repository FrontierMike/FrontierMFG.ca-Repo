---
---
<section id="contact" class="bg-dark py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 xl:gap-24">

      <!-- Left column -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-6 h-px bg-accent"></div>
          <span class="font-display text-[11px] font-semibold tracking-[0.22em] uppercase text-accent">Get In Touch</span>
        </div>
        <h2
          class="font-display font-extrabold uppercase text-primary mb-6"
          style="font-size: clamp(36px, 4vw, 56px);"
        >LET'S TALK</h2>
        <p class="text-muted text-[15px] leading-relaxed mb-10 max-w-sm">
          Tell us about your project. First call is always free — we respond within one business day.
        </p>

        <ul class="flex flex-col gap-5">
          <li class="flex items-start gap-4">
            <span class="font-display text-[11px] font-semibold tracking-[0.15em] uppercase text-dim w-24 mt-0.5 flex-shrink-0">Web</span>
            <span class="text-muted text-[15px]">frontiermfg.ca</span>
          </li>
          <li class="flex items-start gap-4">
            <span class="font-display text-[11px] font-semibold tracking-[0.15em] uppercase text-dim w-24 mt-0.5 flex-shrink-0">Location</span>
            <span class="text-muted text-[15px]">British Columbia, Canada</span>
          </li>
          <li class="flex items-start gap-4">
            <span class="font-display text-[11px] font-semibold tracking-[0.15em] uppercase text-dim w-24 mt-0.5 flex-shrink-0">Serving</span>
            <span class="text-muted text-[15px]">Western Canada</span>
          </li>
        </ul>
      </div>

      <!-- Right column: form -->
      <div>
        <form id="contact-form" class="flex flex-col gap-5" novalidate>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="first-name" class="block font-display text-[11px] font-semibold tracking-[0.18em] uppercase text-dim mb-2">First Name</label>
              <input
                type="text" id="first-name" name="first-name" required
                placeholder="Mike"
                class="w-full bg-surface border border-white/7 px-4 py-3 text-primary text-[15px] placeholder:text-dim focus:outline-none focus:border-accent/50 transition-colors"
              />
            </div>
            <div>
              <label for="last-name" class="block font-display text-[11px] font-semibold tracking-[0.18em] uppercase text-dim mb-2">Last Name</label>
              <input
                type="text" id="last-name" name="last-name" required
                placeholder="Smith"
                class="w-full bg-surface border border-white/7 px-4 py-3 text-primary text-[15px] placeholder:text-dim focus:outline-none focus:border-accent/50 transition-colors"
              />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="email" class="block font-display text-[11px] font-semibold tracking-[0.18em] uppercase text-dim mb-2">Email</label>
              <input
                type="email" id="email" name="email" required
                placeholder="you@company.com"
                class="w-full bg-surface border border-white/7 px-4 py-3 text-primary text-[15px] placeholder:text-dim focus:outline-none focus:border-accent/50 transition-colors"
              />
            </div>
            <div>
              <label for="company" class="block font-display text-[11px] font-semibold tracking-[0.18em] uppercase text-dim mb-2">Company</label>
              <input
                type="text" id="company" name="company"
                placeholder="Acme Manufacturing"
                class="w-full bg-surface border border-white/7 px-4 py-3 text-primary text-[15px] placeholder:text-dim focus:outline-none focus:border-accent/50 transition-colors"
              />
            </div>
          </div>

          <div>
            <label for="service" class="block font-display text-[11px] font-semibold tracking-[0.18em] uppercase text-dim mb-2">Service of Interest</label>
            <select
              id="service" name="service"
              class="w-full bg-surface border border-white/7 px-4 py-3 text-primary text-[15px] focus:outline-none focus:border-accent/50 transition-colors appearance-none cursor-pointer"
            >
              <option value="">Select a service...</option>
              <option value="Process Automation">Process Automation</option>
              <option value="PLC / SCADA Programming">PLC / SCADA Programming</option>
              <option value="Hardware & Software Integration">Hardware &amp; Software Integration</option>
              <option value="Controls Design">Controls Design</option>
              <option value="Manufacturing Process Improvement">Manufacturing Process Improvement</option>
              <option value="Feasibility Study">Feasibility Study</option>
              <option value="Design for Manufacturing">Design for Manufacturing</option>
              <option value="Machining Consultation">Machining Consultation</option>
              <option value="Not sure yet">Not sure yet</option>
            </select>
          </div>

          <div>
            <label for="message" class="block font-display text-[11px] font-semibold tracking-[0.18em] uppercase text-dim mb-2">Message</label>
            <textarea
              id="message" name="message" rows="5" required
              placeholder="Tell us about your project or challenge..."
              class="w-full bg-surface border border-white/7 px-4 py-3 text-primary text-[15px] placeholder:text-dim focus:outline-none focus:border-accent/50 transition-colors resize-none"
            ></textarea>
          </div>

          <!-- Honeypot — hidden from humans; bots that fill it are rejected server-side -->
          <div style="position:absolute; left:-9999px;" aria-hidden="true">
            <label for="company-website">Company Website</label>
            <input
              type="text" id="company-website" name="company-website"
              tabindex="-1" autocomplete="off"
            />
          </div>

          <button
            type="submit"
            class="w-full bg-accent hover:bg-accent-dark text-dark font-display font-bold text-[13px] tracking-[0.1em] uppercase py-4 transition-all duration-200 hover:-translate-y-0.5 cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0"
          >
            Send Message
          </button>

        </form>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;

  if (form) {
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const defaultLabel = button.textContent;

    // Status line, inserted right after the submit button
    const status = document.createElement('p');
    status.className = 'text-[14px] mt-1';
    status.setAttribute('role', 'status');
    button.insertAdjacentElement('afterend', status);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.textContent = '';

      const data = new FormData(form);
      const payload = {
        'first-name':      (data.get('first-name')      as string) || '',
        'last-name':       (data.get('last-name')       as string) || '',
        'email':           (data.get('email')           as string) || '',
        'company':         (data.get('company')         as string) || '',
        'service':         (data.get('service')         as string) || '',
        'message':         (data.get('message')         as string) || '',
        'company-website': (data.get('company-website') as string) || '', // honeypot
      };

      button.disabled = true;
      button.textContent = 'Sending…';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const result = await res.json().catch(() => ({ ok: false }));

        if (res.ok && result.ok) {
          form.reset();
          status.className = 'text-[14px] mt-1 text-accent';
          status.textContent = "Thanks — your message has been sent. We'll respond within one business day.";
          button.textContent = 'Message Sent';
        } else {
          status.className = 'text-[14px] mt-1 text-red-400';
          status.textContent = result.error || 'Something went wrong. Please email info@frontiermfg.ca directly.';
          button.disabled = false;
          button.textContent = defaultLabel;
        }
      } catch {
        status.className = 'text-[14px] mt-1 text-red-400';
        status.textContent = 'Network error. Please email info@frontiermfg.ca directly.';
        button.disabled = false;
        button.textContent = defaultLabel;
      }
    });
  }
</script>
