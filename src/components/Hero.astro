---
---
<section class="min-h-screen bg-dark flex items-center pt-16">
  <div class="max-w-7xl mx-auto px-6 w-full py-20 lg:py-0">
    <div class="grid lg:grid-cols-2 gap-12 xl:gap-24 items-center min-h-[calc(100vh-4rem)]">

      <!-- Left content -->
      <div class="flex flex-col justify-center">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-px bg-accent flex-shrink-0"></div>
          <span class="font-display text-[11px] font-semibold tracking-[0.22em] uppercase text-accent">
            Automation & Manufacturing Consulting
          </span>
        </div>

        <h1
          class="font-display font-extrabold uppercase leading-none text-primary mb-6"
          style="font-size: clamp(52px, 6vw, 84px); letter-spacing: 0.02em;"
        >
          BUILT FOR THE<br /><span class="text-accent">SHOP</span> FLOOR
        </h1>

        <p class="text-muted text-[15px] leading-relaxed mb-10 max-w-[480px]">
          We help manufacturers in Western Canada automate processes, improve production workflows,
          and integrate industrial systems — practical solutions that deliver real results on the shop floor.
        </p>

        <div class="flex flex-wrap items-center gap-6">
          <a
            href="#contact"
            class="bg-accent hover:bg-accent-dark text-dark font-display font-bold text-[13px] tracking-[0.1em] uppercase px-7 py-4 transition-all duration-200 hover:-translate-y-0.5"
          >
            Book a Free Consultation
          </a>
          <a
            href="#services"
            class="font-display font-semibold text-[13px] tracking-[0.1em] uppercase text-muted hover:text-accent transition-colors duration-200"
          >
            View Services →
          </a>
        </div>
      </div>

      <!-- Right: grid pattern + stats -->
      <div
        class="relative hidden lg:flex items-end justify-end min-h-[520px]"
        style="background-image: repeating-linear-gradient(rgba(232,160,32,0.05) 0px, rgba(232,160,32,0.05) 1px, transparent 1px, transparent 60px), repeating-linear-gradient(90deg, rgba(232,160,32,0.05) 0px, rgba(232,160,32,0.05) 1px, transparent 1px, transparent 60px);"
      >
        <div class="absolute bottom-8 right-0 flex flex-col gap-3">
          <div class="bg-surface border border-white/7 px-7 py-5">
            <div class="font-display font-extrabold text-primary leading-none tracking-tight" style="font-size: 2.5rem;">40+</div>
            <div class="font-display text-[11px] font-semibold tracking-[0.18em] uppercase text-dim mt-2">Years Combined Experience</div>
          </div>
          <div class="bg-surface border border-white/7 px-7 py-5">
            <div class="font-display font-extrabold text-primary leading-none tracking-tight" style="font-size: 2.5rem;">BC</div>
            <div class="font-display text-[11px] font-semibold tracking-[0.18em] uppercase text-dim mt-2">Based in Canada</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
