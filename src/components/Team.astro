---
---
<section id="about" class="bg-dark py-24">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-6 h-px bg-accent"></div>
        <span class="font-display text-[11px] font-semibold tracking-[0.22em] uppercase text-accent">Who We Are</span>
      </div>
      <h2
        class="font-display font-extrabold uppercase text-primary mb-4"
        style="font-size: clamp(36px, 4vw, 56px);"
      >THE TEAM</h2>
      <p class="text-muted text-[15px] max-w-xl leading-relaxed">
        A two-person firm combining deep manufacturing and process knowledge with 40 years of senior hardware and software experience.
      </p>
    </div>

    <!-- Team grid -->
    <div class="grid md:grid-cols-2 gap-8 mb-12">

      <!-- Mike W -->
      <div class="bg-card border border-white/7 p-8">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-10 h-10 border border-accent flex items-center justify-center flex-shrink-0">
            <span class="font-display font-bold text-[13px] tracking-wider text-accent">MW</span>
          </div>
          <div>
            <h3 class="font-display font-bold text-[20px] uppercase tracking-[0.05em] text-primary">Mike W.</h3>
            <p class="font-display text-[11px] font-semibold tracking-[0.12em] uppercase text-accent mt-1">
              EIT · Automation & Manufacturing Consultant
            </p>
          </div>
        </div>
        <p class="text-muted text-[15px] leading-relaxed">
          Registered Engineer-in-Training with hands-on expertise in automation, manufacturing process improvement,
          PLC/SCADA programming, and design for manufacturing. Focused on practical solutions for production floor challenges.
        </p>
      </div>

      <!-- Gord W -->
      <div class="bg-card border border-white/7 p-8">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-10 h-10 border border-accent flex items-center justify-center flex-shrink-0">
            <span class="font-display font-bold text-[13px] tracking-wider text-accent">GW</span>
          </div>
          <div>
            <h3 class="font-display font-bold text-[20px] uppercase tracking-[0.05em] text-primary">Gord W.</h3>
            <p class="font-display text-[11px] font-semibold tracking-[0.12em] uppercase text-accent mt-1">
              Software & Hardware Engineer · 40 Years Experience
            </p>
          </div>
        </div>
        <p class="text-muted text-[15px] leading-relaxed">
          Senior software and hardware engineer with four decades of experience in industrial systems, embedded development,
          and technology leadership. Has held senior roles across multiple industries — bringing deep technical credibility
          to every engagement.
        </p>
      </div>

    </div>

    <!-- EIT Disclaimer -->
    <div class="border-l-[3px] border-accent px-6 py-5" style="background-color: rgba(232,160,32,0.05);">
      <p class="text-muted text-[14px] leading-relaxed">
        Frontier Manufacturing Services is operated by a registered Engineer-in-Training (EIT) in British Columbia.
        We provide consulting and technical services; we do not offer licensed professional engineering services.
      </p>
    </div>

  </div>
</section>
